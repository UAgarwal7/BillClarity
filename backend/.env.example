# BillClarity Backend — Environment Variables

# AWS — Core
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=billclarity-docs

# AWS — SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/billclarity-parsing-jobs
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/billclarity-parsing-dlq

# AWS — Lambda
LAMBDA_FUNCTION_NAME=billclarity-parsing-trigger

# Pipeline Mode: "local" for dev (BackgroundTasks), "aws" for Lambda-driven
PIPELINE_MODE=local

# Google Gemini
GEMINI_API_KEY=

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/billclarity

# ElevenLabs (stretch)
ELEVENLABS_API_KEY=

# n8n (stretch)
N8N_BASE_URL=http://localhost:5678

# Server
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
